# LLM Configuration (Required for AI Feedback)
# Example: http://localhost:8080/v1/chat/completions
LLM_ENDPOINT=http://localhost:8080/v1/chat/completions
# Leave empty if your local LLM server doesn't require an API key
LLM_API_KEY=your_api_key_here

# No ElevenLabs needed - we use edge-tts locally for text-to-speech
